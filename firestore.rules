rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // users/{uid} — each user owns their own profile
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // groups/{groupId} — readable by signed-in users, owner can write
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      // Owner can update anything; any signed-in user may bump memberCount/updatedAt
      // (used by the join transaction). Other fields are owner-only.
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['memberCount', 'updatedAt'])
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // groupMembers/{groupId_uid} — top-level collection
    // readable by any signed-in user
    // createable by the user themselves (uid must match their auth uid)
    // deletable by self or the group's creator
    match /groupMembers/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.uid == request.auth.uid ||
         get(/databases/$(database)/documents/groups/$(memberId.split('_')[0])).data.createdBy == request.auth.uid);
      allow update: if isSignedIn() &&
        (resource.data.uid == request.auth.uid ||
         get(/databases/$(database)/documents/groups/$(memberId.split('_')[0])).data.createdBy == request.auth.uid);
    }

    // groupStats/{groupId_uid} — top-level collection
    // readable by any signed-in user
    // writable only by users who are members of that group
    match /groupStats/{statId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        exists(/databases/$(database)/documents/groupMembers/$(statId));
    }

    // sessions/{sessionId} — owners read/write their own
    match /sessions/{sessionId} {
      allow read, write: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }
    // userData/{uid_tableName} — per-user data sync (focus areas, marks, etc.)
    // Doc IDs are formatted as `${uid}_${tableName}`.
    // Only the owning user can read or write their own data.
    match /userData/{docId} {
      allow read, write: if isSignedIn() && docId.matches('^' + request.auth.uid + '_.*');
    }
    // userSettings/{uid} — per-user settings/widget/nav prefs
    match /userSettings/{uid} {
      allow read, write: if isOwner(uid);
    }
  }
}
