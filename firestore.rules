rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // users/{uid} — each user owns their own profile
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // groups/{groupId} — readable by signed-in users, owner can write
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // groupMembers/{groupId_uid} — top-level collection
    // readable by any signed-in user
    // createable by the user themselves (uid must match their auth uid)
    // deletable by self or the group's creator
    match /groupMembers/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.uid == request.auth.uid ||
         get(/databases/$(database)/documents/groups/$(memberId.split('_')[0])).data.createdBy == request.auth.uid);
      allow update: if isSignedIn() &&
        (resource.data.uid == request.auth.uid ||
         get(/databases/$(database)/documents/groups/$(memberId.split('_')[0])).data.createdBy == request.auth.uid);
    }

    // groupStats/{groupId_uid} — top-level collection
    // readable by any signed-in user
    // writable only by users who are members of that group
    match /groupStats/{statId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        exists(/databases/$(database)/documents/groupMembers/$(statId));
    }

    // sessions/{sessionId} — owners read/write their own
    match /sessions/{sessionId} {
      allow read, write: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }
  }
}
